# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/vmcmoto_edu

# Database Pool Settings
POOL_SIZE=10
MAX_OVERFLOW=20
POOL_RECYCLE=3600

# Security Settings
SECRET_KEY=your-super-secret-key-change-in-production
ADMIN_PASSWORD=admin123
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_DIR=app/static/uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# CORS Settings (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Application Settings
PROJECT_NAME=VMC Moto Education Portal
VERSION=1.0.0
DEBUG=true

# Hugging Face Integration (optional)
HF_API_TOKEN=your-hugging-face-token

# PostgreSQL Database Setup Instructions:
# 1. Install PostgreSQL
# 2. Create database: createdb vmcmoto_edu
# 3. Create user: createuser -P vmcmoto_user
# 4. Grant permissions: GRANT ALL PRIVILEGES ON DATABASE vmcmoto_edu TO vmcmoto_user; 